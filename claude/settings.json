{
  "env": {
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-sonnet-4-6[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6[1m]"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "deny": [
      "Bash(git push:*)"
    ],
    "defaultMode": "plan"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "context7-plugin@context7-marketplace": true,
    "example-skills@anthropic-agent-skills": true,
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "code-review@claude-code-plugins": true,
    "claude-md-management@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "gopilot@gopilot": true,
    "swift-lsp@claude-plugins-official": true,
    "telegram@claude-plugins-official": true,
    "interface-design@interface-design": true,
    "td-aiguide@td-aiguide": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "interface-design": {
      "source": {
        "source": "github",
        "repo": "Dammyjay93/interface-design"
      },
      "autoUpdate": true
    },
    "td-aiguide": {
      "source": {
        "source": "git",
        "url": "git@github.com:timescale/td-aiguide.git"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "fastMode": true,
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "mcpServers": {
    "sc": {
      "args": [
        "mcp",
        "serve",
        "--stdio"
      ],
      "command": "sc"
    }
  }
}
